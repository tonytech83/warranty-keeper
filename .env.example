# Copy this file to .env and adjust the values.

# --- Django ---
# Generate a new key, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string

# Set to False in production / when exposing the app.
DEBUG=True

# Comma-separated list of hosts allowed to serve the app.
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# Currency symbol shown next to prices.
CURRENCY=€

# --- SQLite ---
# Path to the database file. Leave unset to default to ./db.sqlite3.
# In Docker this is set to /app/data/db.sqlite3 (a mounted volume).
# SQLITE_PATH=db.sqlite3

# --- Docker host paths (docker-compose only) ---
# Host folders bind-mounted into the container for the DB and uploaded media.
# Default to ./data and ./mediafiles next to docker-compose.yml.
# Point these at a NAS/share for easy backups. NOTE: if the target is an
# SMB/CIFS share, mount it with `nobrl` or SQLite will report "database is
# locked" (see README).
# DATA_DIR=/mnt/omv-smb-share/docker-volumes/warranty-keeper/data
# MEDIA_DIR=/mnt/omv-smb-share/docker-volumes/warranty-keeper/media
