# Copy this file to .env and adjust the values.

# --- Django ---
# Generate a new key, e.g.
SECRET_KEY=change-me-to-a-long-random-string

# Set to False in production / when exposing the app.
DEBUG=True

# Comma-separated list of hosts allowed to serve the app.
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# Currency symbol shown next to prices.
CURRENCY=€

# --- Database (MariaDB) ---
# These are shared by the `db` container (which creates the database and user)
# and the `web` container (which connects to it).
DB_NAME=warranty-keeper
DB_USER=warranty
DB_PASSWORD=change-me-db-password
# Root password for the MariaDB container (admin tasks only).
DB_ROOT_PASSWORD=change-me-root-password
DB_HOST=db
DB_PORT=3306

# --- Docker host paths (docker-compose only) ---
# Uploaded media live on a NAS/share:
#   MEDIA_DIR -> uploaded invoices & supplier logos (defaults to ./mediafiles)
# MEDIA_DIR=/mnt/omv-smb-share/docker-volumes/warranty-keeper/media
